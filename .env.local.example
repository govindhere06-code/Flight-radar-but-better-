# OpenSky Network API
# Get your API key from: https://opensky-network.org
NEXT_PUBLIC_OPENSKY_API_URL=https://opensky-network.org/api
NEXT_PUBLIC_OPENSKY_USERNAME=your_opensky_username
NEXT_PUBLIC_OPENSKY_PASSWORD=your_opensky_password

# Aviationstack API
# Get your API key from: https://aviationstack.com
NEXT_PUBLIC_AVIATIONSTACK_API_KEY=your_aviationstack_api_key
NEXT_PUBLIC_AVIATIONSTACK_API_URL=http://api.aviationstack.com/v1

# Optional: For backend API calls (if using backend routes)
OPENSKY_USERNAME=your_opensky_username
OPENSKY_PASSWORD=your_opensky_password
AVIATIONSTACK_API_KEY=your_aviationstack_api_key
